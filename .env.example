# ---------- Supabase ----------
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# 서버 전용 (절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------- 학생 세션 서명 ----------
# 반코드 로그인 학생 세션 JWT 서명용 시크릿 (임의의 긴 랜덤 문자열)
STUDENT_SESSION_SECRET=change-me-to-a-long-random-string

# ---------- OpenAI (샘플 음성 TTS) ----------
OPENAI_API_KEY=sk-...
# 선택: 샘플 음성 보이스 (alloy | echo | fable | onyx | nova | shimmer)
OPENAI_TTS_VOICE=nova

# ---------- Azure Speech (발음 평가) — 선택 ----------
# 설정하면 음소 단위 정밀 발음평가 사용. 비워두면 자동으로 OpenAI(Whisper) 대체 평가 사용.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ---------- LLM 피드백 (Anthropic Claude) ----------
ANTHROPIC_API_KEY=sk-ant-...

# ---------- 음원 자동삭제 크론 보호 (Vercel Cron) ----------
# 임의의 긴 랜덤 문자열. Vercel Cron 이 이 값으로 /api/cron/cleanup 을 인증.
CRON_SECRET=change-me-to-a-long-random-string
